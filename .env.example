# Telegram
BOT_TOKEN=                  # @BotFather token
TELEGRAM_CHANNEL_ID=        # e.g. -1001234567890

# AI provider selection
# Choose one: claude | chatgpt | gemini | deepseek | groq
# Leave empty to disable AI — posts will be published as URL only (no announcement, no hashtags)
AI_PROVIDER=claude

# AI API keys — only the key for the selected provider is required
ANTHROPIC_API_KEY=          # AI_PROVIDER=claude   → console.anthropic.com
OPENAI_API_KEY=             # AI_PROVIDER=chatgpt  → platform.openai.com
GEMINI_API_KEY=             # AI_PROVIDER=gemini   → aistudio.google.com
DEEPSEEK_API_KEY=           # AI_PROVIDER=deepseek → platform.deepseek.com
GROQ_API_KEY=               # AI_PROVIDER=groq     → console.groq.com (free tier available)

# Local Whisper transcription (faster-whisper, no API key required)
# Model sizes: tiny | base | small | medium | large-v2 | large-v3
#   tiny ~75MB, base ~150MB, small ~500MB, medium ~1.5GB, large ~3GB
WHISPER_MODEL=base
# Device: cpu | cuda  (use cuda if NVIDIA GPU is available)
WHISPER_DEVICE=cpu

# Database
POSTGRES_DB=tgbot
POSTGRES_USER=tgbot
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# Auth
OWNER_IDS=                  # comma-separated Telegram user IDs, e.g. 123456,789012

# Optional
GITHUB_TOKEN=               # optional, for higher GitHub API rate limits

# Docker
ENV=dev                     # dev | prod
RESTART_POLICY=unless-stopped  # unless-stopped (dev) | always (prod)

# Logging
LOG_LEVEL=DEBUG             # DEBUG for dev, INFO for prod
